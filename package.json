{
  "name": "portfolio-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:build": "npm run build && vitest run tests/build.test.ts",
    "test:content": "vitest run tests/content.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "test:all": "npm run test && npm run test:build && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@supabase/supabase-js": "^2.45.0",
    "astro": "^6.1.3",
    "nodemailer": "^6.9.13",
    "resend": "^6.0.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/nodemailer": "^6.4.14",
    "@vitest/ui": "^4.1.2",
    "vitest": "^4.1.2"
  }
}
