---
// Clippy easter egg — animated via felixrieseberg/clippy sprite sheet
// Animation assets: MIT license, © Felix Rieseberg
// Clippy character: Microsoft IP, used in the spirit of the Clippy renaissance
import mapPng from '../assets/clippy/map.png';
import animData from '../assets/clippy/animations.json';

const mapUrl = mapPng.src;
const animations = animData as Array<{ Name: string; Frames: Array<{ Duration: number; ImagesOffsets: { Column: number; Row: number } | null }> }>;

const IDLE_ANIMATIONS = animations
  .filter(a => a.Name.startsWith('Idle') || a.Name === 'Idle1_1')
  .map(a => a.Name);

const SHOW_ANIMATION  = 'Show';
const GREET_ANIMATION = 'Wave';
---

<div id="clippy-wrap" aria-live="polite">
  <div id="clippy-bubble" role="dialog" aria-label="Clippy has a suggestion">
    <button id="clippy-close" aria-label="Dismiss Clippy forever" title="Dismiss forever">✕</button>
    <p id="clippy-msg"></p>
    <div class="clippy-slider-row">
      <span class="clippy-slider-label">No Clippy</span>
      <input type="range" id="clippy-prob" min="0" max="100" step="1" value="100"
             aria-label="Clippy frequency" title="Adjust how often Clippy appears" />
      <span class="clippy-slider-label">Maximum Clippy</span>
    </div>
  </div>

  <div id="clippy-char" aria-hidden="true"></div>
</div>

<button id="clippy-recall" title="Bring back Clippy" aria-label="Bring back Clippy">
  📎
</button>

<style define:vars={{ mapUrl: `url(${mapPng.src})` }}>
  #clippy-wrap {
    position: fixed;
    bottom: 2rem;
    right: 1.5rem;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1000;
    animation: clippy-appear 0.3s ease-out;
  }

  @keyframes clippy-appear {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #clippy-bubble {
    background: #fffde7;
    border: 2px solid #555;
    border-radius: 10px;
    padding: 0.65rem 1.1rem 0.6rem 0.9rem;
    max-width: 240px;
    font-size: 0.78rem;
    line-height: 1.45;
    position: relative;
    box-shadow: 3px 3px 10px rgba(0,0,0,0.18);
    font-family: 'Inter', sans-serif;
    color: #2C2C2C;
  }

  #clippy-bubble::after {
    content: '';
    position: absolute;
    bottom: -9px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 9px solid #fffde7;
    z-index: 1;
  }
  #clippy-bubble::before {
    content: '';
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 9px solid transparent;
    border-right: 9px solid transparent;
    border-top: 11px solid #555;
  }

  #clippy-close {
    position: absolute;
    top: 5px;
    right: 7px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.65rem;
    color: #aaa;
    padding: 0;
    line-height: 1;
    font-family: monospace;
  }
  #clippy-close:hover { color: #333; }

  #clippy-msg {
    margin: 0 0 0.6rem 0;
    padding-right: 0.75rem;
  }

  .clippy-slider-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    border-top: 1px solid #e8e4c8;
    padding-top: 0.45rem;
  }

  .clippy-slider-label {
    font-size: 0.6rem;
    color: #888;
    white-space: nowrap;
    line-height: 1;
  }

  #clippy-prob {
    flex: 1;
    height: 3px;
    cursor: pointer;
    accent-color: #C8A017;
    min-width: 0;
  }

  #clippy-char {
    width: 124px;
    height: 93px;
    background-image: var(--mapUrl);
    background-repeat: no-repeat;
    cursor: pointer;
    filter: drop-shadow(1px 2px 4px rgba(0,0,0,0.2));
    transition: filter 0.15s ease;
    image-rendering: pixelated;
  }
  #clippy-char:hover { filter: drop-shadow(1px 3px 6px rgba(0,0,0,0.3)); }

  #clippy-recall {
    position: fixed;
    bottom: 1rem;
    right: 1.5rem;
    background: rgba(249, 247, 244, 0.92);
    border: 1px solid var(--border, #D8D4CC);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    z-index: 999;
    display: none;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(44,44,44,0.12);
    transition: transform 0.15s, background 0.15s;
    padding: 0;
  }
  #clippy-recall:hover {
    background: white;
    transform: scale(1.15) rotate(15deg);
  }
</style>

<script define:vars={{ mapUrl, animations, IDLE_ANIMATIONS, SHOW_ANIMATION, GREET_ANIMATION }}>
  const PROB_KEY = 'clippy_probability';
  const FRAME_W  = 124;
  const FRAME_H  = 93;

  // ── Messages ────────────────────────────────────────────────────────────────
  const GENERIC = [
    "It looks like you're designing an LLM. Would you like help? [Yes]  [No]  [Don't ask me again (until the next page)]",
    "It looks like you're building an AI portfolio. I'm an AI. Is this awkward for you?",
    "It looks like you're writing infrastructure code. Have you tried turning it off and on again?",
    "It looks like you're reading about agents. I was an agent once. It didn't end well.",
  ];
  const SESSION = [
    "It looks like you're taking session notes. Would you like me to format that as a bulleted list? Actually, you don't have a choice.",
    "It looks like you're reading about token costs. Your Opus 4.6 run was $0.39. Just saying.",
  ];
  const PROJECT = [
    "It looks like you're building a RAG system. I prefer being paper-clipped to things, personally.",
    "It looks like you're building a multi-agent system. We used to call that 'firing half the team.'",
    "It looks like you're evaluating LLM models. I was evaluated once. Retired shortly after.",
  ];
  const ABOUT = [
    "It looks like you're reading an origin story. Mine started in Office 97. We don't talk about that.",
  ];

  function getPool() {
    const p = window.location.pathname;
    if (p.includes('/blog/how-i-got-here') || p.includes('/about')) return [...ABOUT, ...GENERIC];
    if (p.includes('/blog/session-')) return [...SESSION, ...GENERIC];
    if (p.includes('/blog/project-')) return [...PROJECT, ...GENERIC];
    return GENERIC;
  }

  let lastMsg = '';
  function pickMsg() {
    const pool = getPool().filter(m => m !== lastMsg);
    const msg = pool[Math.floor(Math.random() * pool.length)];
    lastMsg = msg;
    return msg;
  }

  // ── Animation engine ────────────────────────────────────────────────────────
  const animMap = {};
  for (const a of animations) animMap[a.Name] = a.Frames;

  const charEl = document.getElementById('clippy-char');
  let animTimer = null;
  let idleTimer  = null;

  function setFrame(frame) {
    if (!frame || !frame.ImagesOffsets) return;
    const { Column, Row } = frame.ImagesOffsets;
    charEl.style.backgroundPosition =
      `-${Column * FRAME_W}px -${Row * FRAME_H}px`;
  }

  function playAnimation(name, onDone) {
    clearTimeout(animTimer);
    const frames = animMap[name];
    if (!frames || !frames.length) { onDone && onDone(); return; }
    let i = 0;
    function step() {
      if (i >= frames.length) { onDone && onDone(); return; }
      setFrame(frames[i]);
      animTimer = setTimeout(step, frames[i].Duration || 100);
      i++;
    }
    step();
  }

  function pickIdle() {
    const choices = IDLE_ANIMATIONS.filter(n => animMap[n]);
    return choices[Math.floor(Math.random() * choices.length)];
  }

  function loopIdle() {
    clearTimeout(idleTimer);
    playAnimation(pickIdle(), () => {
      idleTimer = setTimeout(loopIdle, 4000 + Math.random() * 4000);
    });
  }

  function startIdle() {
    idleTimer = setTimeout(loopIdle, 2000);
  }

  // ── DOM refs ────────────────────────────────────────────────────────────────
  const wrap      = document.getElementById('clippy-wrap');
  const msgEl     = document.getElementById('clippy-msg');
  const closeBtn  = document.getElementById('clippy-close');
  const recallBtn = document.getElementById('clippy-recall');
  const slider    = document.getElementById('clippy-prob');

  function getProb() { return parseInt(localStorage.getItem(PROB_KEY) ?? '100'); }
  function setProb(v) { localStorage.setItem(PROB_KEY, String(v)); }

  function show() {
    msgEl.textContent = pickMsg();
    slider.value = String(getProb());
    wrap.style.display = 'flex';
    recallBtn.style.display = 'none';
    // Play Show → Wave → idle loop
    playAnimation(SHOW_ANIMATION, () => {
      playAnimation(GREET_ANIMATION, startIdle);
    });
  }

  function hide() {
    clearTimeout(animTimer);
    clearTimeout(idleTimer);
    wrap.style.display = 'none';
  }

  function dismiss() {
    setProb(0);
    hide();
    recallBtn.style.display = 'flex';
  }

  closeBtn.addEventListener('click', (e) => { e.stopPropagation(); dismiss(); });
  charEl.addEventListener('click', dismiss);

  recallBtn.addEventListener('click', () => {
    setProb(100);
    recallBtn.style.display = 'none';
    show();
  });

  slider.addEventListener('input', () => {
    const val = parseInt(slider.value);
    setProb(val);
    if (val === 0) {
      msgEl.textContent = "Fine. I'll go quietly.";
      clearTimeout(idleTimer);
      setTimeout(dismiss, 1800);
    }
  });

  // ── Init ────────────────────────────────────────────────────────────────────
  charEl.style.backgroundImage = `url(${mapUrl})`;
  const prob = getProb();
  if (prob === 0) {
    recallBtn.style.display = 'flex';
  } else if (Math.random() * 100 < prob) {
    setTimeout(show, 1200);
  }
</script>

