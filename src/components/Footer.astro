---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p>&copy; {today.getFullYear()} Mike McMahon. Built with <a href="https://astro.build">Astro</a> and <a href="https://claude.ai">Claude</a>.</p>
		<p><a href="/subscribe">Subscribe to new posts</a> or <a href="/rss.xml">use RSS</a></p>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-content {
		max-width: 800px;
		margin: 0 auto;
	}
	footer p {
		margin: 0.5em 0;
		font-size: 0.95rem;
	}
	footer a {
		color: var(--accent);
		text-decoration: none;
	}
	footer a:hover {
		text-decoration: underline;
	}
</style>
